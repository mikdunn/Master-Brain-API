OPENAI_API_KEY=
PERPLEXITY_API_KEY=
OPENAI_EMBED_MODEL=text-embedding-3-small
CLOUD_RERANK_ENABLED=1
BRIDGE_API_KEY=your_bridge_api_key_here
BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8787
BRIDGE_DEFAULT_INDEX_PATH=data/master_brain_index.pkl
BRIDGE_WORKSPACE_ROOT=
MASTER_BRAIN_ROOT=

# Public/shared deployment safety
BRIDGE_PUBLIC_MODE=0
BRIDGE_PUBLIC_MAX_K=10
BRIDGE_PUBLIC_ALLOW_ADMIN_ENDPOINTS=0
BRIDGE_PUBLIC_RETURN_CONTEXT=0

# Best-effort in-process rate limiting
BRIDGE_RATE_LIMIT_RPM=60
BRIDGE_RATE_LIMIT_BURST=20

# BigQuery telemetry (analytics plane, fail-open)
BQ_TELEMETRY_ENABLED=0
BQ_PROJECT_ID=
BQ_DATASET_ID=master_brain_analytics
BQ_QUERY_TABLE=query_telemetry
BQ_RETRIEVAL_HITS_TABLE=retrieval_hits
BQ_BUILD_RUNS_TABLE=build_runs
BQ_FILE_INVENTORY_TABLE=file_inventory_snapshot
BQ_CHUNK_METADATA_TABLE=chunk_metadata_catalog
BQ_TIMELINE_EVENTS_TABLE=timeline_events
BQ_INSERT_TIMEOUT_SECONDS=1
BQ_FLUSH_BATCH_SIZE=50
BQ_FLUSH_INTERVAL_SECONDS=2
BQ_QUEUE_MAXSIZE=2000
BQ_INCLUDE_QUESTION_TEXT=0
