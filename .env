# Master Brain Bridge API environment
#
# Notes:
# - The API will fall back to BRIDGE_API_KEY=master-brain-bridge-local if unset.
# - If you set BRIDGE_WORKSPACE_ROOT, a relative BRIDGE_DEFAULT_INDEX_PATH will be resolved under it.

BRIDGE_HOST=127.0.0.1
BRIDGE_PORT=8787

# Use a non-placeholder value if you want to require an explicit key.
# For purely local usage, the default fallback key is fine.
BRIDGE_API_KEY=master-brain-bridge-local

# Optional: set these on each machine to avoid path ambiguity.
# BRIDGE_WORKSPACE_ROOT=C:/Users/you/path/to/Master-Brain-API
# BRIDGE_DEFAULT_INDEX_PATH=data/master_brain_index.pkl

# Optional (used by CLI flows):
# MASTER_BRAIN_ROOT=C:/Users/you/Dropbox/Apps/Master Brain

# Optional cloud features:
# OPENAI_API_KEY=your_openai_api_key_here
# PERPLEXITY_API_KEY=your_perplexity_api_key_here

# Optional behavior:
# CLOUD_RERANK_ENABLED=1
