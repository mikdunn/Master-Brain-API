{
  "manifest_version": 3,
  "name": "Master Brain First",
  "version": "0.1.0",
  "description": "Intercept chat submit, ground prompt via local Master Brain bridge, then submit.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://127.0.0.1:8787/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://www.perplexity.ai/*",
    "https://perplexity.ai/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.perplexity.ai/*",
        "https://perplexity.ai/*"
      ],
      "js": [
        "content.js"
      ],
      "run_at": "document_start"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "Master Brain First"
  }
}
