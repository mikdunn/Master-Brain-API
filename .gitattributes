# Normalize line endings for text files across platforms
# Keeps the repo consistent and prevents CRLF/LF churn.
* text=auto eol=lf

# Windows scripts
*.ps1 text eol=crlf
*.bat text eol=crlf
*.cmd text eol=crlf

# Common binary formats
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
